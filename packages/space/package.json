{
  "name": "@daddia/space",
  "version": "0.2.0",
  "description": "Operate a delivery workspace -- sync sources, publish docs",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daddia/space.git",
    "directory": "packages/space"
  },
  "keywords": [
    "daddia",
    "space",
    "delivery",
    "sync",
    "jira",
    "confluence"
  ],
  "engines": {
    "node": ">=24.14.1"
  },
  "bin": {
    "space": "./dist/index.js"
  },
  "files": [
    "dist",
    "template",
    "profiles",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "dev": "tsc --watch --project tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@daddia/typescript-config": "workspace:*",
    "@types/node": "^25.6.0",
    "msw": "^2.14.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
