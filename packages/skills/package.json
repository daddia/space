{
  "name": "@daddia/skills",
  "version": "0.4.0",
  "type": "module",
  "description": "Delivery activity skills for AI coding agents -- works with any IDE",
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/templeandwebster/horizon/space.git",
    "directory": "packages/skills"
  },
  "keywords": [
    "horizon",
    "space",
    "skills",
    "delivery",
    "ai-agents",
    "cursor",
    "claude-code",
    "copilot"
  ],
  "engines": {
    "node": ">=24.14.1"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run",
    "lint:skills": "node dist/cli/lint.js",
    "generate:index": "node dist/cli/generate.js index",
    "generate:views": "node dist/cli/generate.js views",
    "validate:public": "node dist/cli/validate-public.js"
  },
  "bin": {
    "lint-skills": "dist/cli/lint.js",
    "generate-index": "dist/cli/generate.js index",
    "generate-views": "dist/cli/generate.js views",
    "validate-public": "dist/cli/validate-public.js"
  },
  "files": [
    "dist/**",
    "bin/**",
    "*/SKILL.md",
    "*/template.md",
    "*/template-*.md",
    "*/template.*.md",
    "*/examples/**",
    "*/scripts/**",
    "views/**",
    "profiles/**",
    "README.md",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@daddia/typescript-config": "workspace:*",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
