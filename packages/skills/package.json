{
  "name": "@daddia/skills",
  "version": "1.0.0",
  "type": "module",
  "description": "Delivery activity skills for AI coding agents -- works with any IDE",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daddia/space.git",
    "directory": "packages/skills"
  },
  "keywords": [
    "daddia",
    "space",
    "skills",
    "delivery",
    "ai-agents",
    "cursor",
    "claude-code",
    "copilot"
  ],
  "engines": {
    "node": ">=24.14.1"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run",
    "lint:skills": "node dist/cli/lint.js",
    "generate:index": "node dist/cli/generate.js index",
    "generate:views": "node dist/cli/generate.js views",
    "validate:public": "node dist/cli/validate-public.js",
    "sync-public": "node dist/cli/sync-public.js"
  },
  "bin": {
    "lint-skills": "dist/cli/lint.js",
    "generate-index": "dist/cli/generate.js index",
    "generate-views": "dist/cli/generate.js views",
    "validate-public": "dist/cli/validate-public.js",
    "sync-public-skills": "dist/cli/sync-public.js"
  },
  "files": [
    "dist",
    "skills",
    "profiles",
    "views",
    "space-index",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "dependencies": {
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@daddia/typescript-config": "workspace:*",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
