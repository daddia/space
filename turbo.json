{
  "$schema": "https://turborepo.dev/schema.json",
  "globalPassThroughEnv": ["npm_config_user_agent", "https_proxy"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
