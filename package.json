{
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "prettier": "@tpw/prettier-config",
  "scripts": {
    "build": "pnpm --filter '@tpw/create-space' --filter '@tpw/space' run build",
    "typecheck": "pnpm --filter '@tpw/create-space' --filter '@tpw/space' run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:skills": "pnpm --filter '@tpw/skills' run lint",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky",
    "clean": "turbo clean",
    "validate": "pnpm validate:build && pnpm validate:quality && pnpm test",
    "validate:build": "pnpm install && pnpm build",
    "validate:quality": "pnpm format:write && pnpm lint:fix && pnpm lint:skills && pnpm typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@tpw/eslint-config": "workspace:*",
    "@tpw/prettier-config": "workspace:*",
    "@tpw/skills": "workspace:*",
    "@tpw/typescript-config": "workspace:*",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.9.5",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
